#     style-src 'self' 'unsafe-inline';
#     img-src 'self' data: blob: https://zsjxauwwqyyhgxzgnfoj.supabase.co;
#     connect-src 'self' https://zsjxauwwqyyhgxzgnfoj.supabase.co wss://zsjxauwwqyyhgxzgnfoj.supabase.co;
#     worker-src 'self';
#     frame-ancestors 'none';
#     object-src 'none';
#     base-uri 'none'
#
# Note: 'unsafe-inline' is required because the app uses inline onclick handlers
# and inline styles throughout. Removing it (the strongest XSS defense) would
# need those refactored first; until then the escaping sweep (v39.68–70) is the
# primary XSS defense and this CSP mainly restricts which external origins can
# be contacted.
